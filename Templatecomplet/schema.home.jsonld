    {
      "@type": "FAQPage",
      "@id": "https://www.jardins-provence-paysage.fr/faq/#faqpage",
      "url": "https://www.jardins-provence-paysage.fr/faq/",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Quel budget prévoir pour créer un jardin méditerranéen ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Le budget dépend de la surface, du niveau de finition, du terrassement, des matériaux et du volume de plantation. Un devis précis permet de cadrer le projet selon les usages et les priorités."
          }
        },
        {
          "@type": "Question",
          "name": "Peut-on avoir un beau jardin en Provence sans beaucoup arroser ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui. En choisissant des végétaux adaptés, un paillage minéral, une bonne gestion des zones d’ombre et un arrosage raisonné, il est possible de créer un jardin esthétique et sobre en eau."
          }
        },
        {
          "@type": "Question",
          "name": "Le composite chauffe-t-il autour d’une piscine ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cela dépend de la gamme, de la couleur et de l’exposition. Les composites haut de gamme bien choisis restent confortables, mais il faut comparer les matériaux selon l’usage réel du lieu."
          }
        },
        {
          "@type": "Question",
          "name": "Installez-vous des systèmes d’arrosage automatique intelligents ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Oui. Nous installons des systèmes d’arrosage automatique pilotables, programmables par zones et conçus pour réduire la consommation d’eau."
          }
        },
        {
          "@type": "Question",
          "name": "Intervenez-vous uniquement à Arles ?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Non. Nous intervenons à Arles, dans les Alpilles, en Camargue et dans plusieurs communes voisines comme Saint-Rémy-de-Provence, Maussane, Mouriès, Les Baux, Tarascon et Beaucaire."
          }
        }
      ]
    },
